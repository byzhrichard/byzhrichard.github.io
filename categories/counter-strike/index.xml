</span></span><span class="line"><span class="cl"><span class="n">cl_radar_rotate</span> <span class="mi">1</span>                   <span class="o">//</span> <span class="err">雷达旋转</span>
</span></span><span class="line"><span class="cl"><span class="n">cl_radar_always_centered</span> <span class="mi">1</span>          <span class="o">//</span> <span class="err">雷达以玩家为中心</span>
</span></span><span class="line"><span class="cl"><span class="n">cl_radar_square_with_scoreboard</span> <span class="mi">1</span>   <span class="o">//</span> <span class="err">切换计分板时全地图</span>
</span></span><span class="line"><span class="cl"><span class="o">//</span><span class="n">cl_radar_scale_alternate</span> <span class="mi">1</span>          <span class="o">//</span> <span class="err">雷达地图切换缩放</span><span class="p">(</span><span class="mf">0.25</span><span class="o">~</span><span class="mi">1</span><span class="p">)</span>
