</span></span><span class="line"><span class="cl"><span class="o">//</span><span class="n">safezoney</span> <span class="mi">1</span>                         <span class="o">//</span> <span class="n">HUD竖直方向缩放百分比</span>
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl"><span class="o">//</span> <span class="err">声音设置</span>
</span></span><span class="line"><span class="cl"><span class="n">snd_tensecondwarning_volume</span> <span class="mf">0.251906</span>
</span></span><span class="line"><span class="cl">
</span></span><span class="line"><span class="cl"><span class="o">//</span> <span class="err">其他设置</span>
