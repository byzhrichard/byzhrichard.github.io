</span></span><span class="line"><span class="cl"><span class="n">cl_hud_telemetry_frametime_show</span> <span class="mi">2</span> <span class="o">//</span> <span class="err">显示帧间时间及</span><span class="n">FPS</span><span class="p">(</span><span class="mi">0</span><span class="err">从不，</span><span class="mi">1</span><span class="err">如果条件恶劣，</span><span class="mi">2</span><span class="err">总是</span><span class="p">)</span>
</span></span><span class="line"><span class="cl"><span class="n">cl_hud_telemetry_ping_show</span> <span class="mi">2</span> <span class="o">//</span> <span class="err">显示延迟</span><span class="p">(</span><span class="mi">0</span><span class="err">从不，</span><span class="mi">1</span><span class="err">如果条件恶劣，</span><span class="mi">2</span><span class="err">总是</span><span class="p">)</span>
</span></span><span class="line"><span class="cl"><span class="n">cl_dm_buyrandomweapons</span> <span class="mi">0</span> <span class="o">//</span> <span class="err">关闭死斗随机买枪</span>
</span></span><span class="line"><span class="cl"><span class="n">mm_dedicated_search_maxping</span> <span class="mi">150</span> <span class="o">//</span> <span class="err">最大匹配延迟</span><span class="n">ms</span>
</span></span><span class="line"><span class="cl"><span class="n">cl_silencer_mode</span> <span class="mi">1</span> <span class="o">//</span> <span class="err">卸下消音器</span><span class="p">(</span><span class="mi">1</span><span class="err">第二开火，</span><span class="mi">0</span><span class="err">已禁用</span><span class="p">)</span>
</span></span><span class="line"><span class="cl"><span class="n">cl_showloadout</span> <span class="mi">1</span> <span class="o">//</span> <span class="err">总是显示物品栏</span><span class="p">(</span><span class="mi">0</span><span class="err">否，</span><span class="mi">1</span><span class="err">是</span><span class="p">)</span>
</span></span><span class="line"><span class="cl"><span class="n">cl_sniper_auto_rezoom</span> <span class="mi">1</span> <span class="o">//</span> <span class="err">开枪后狙击步枪自动重新开镜</span><span class="p">(</span><span class="mi">0</span><span class="err">否，</span><span class="mi">1</span><span class="err">是</span><span class="p">)</span>
</span></span><span class="line"><span class="cl"><span class="n">cl_hud_color</span> <span class="mi">11</span> <span class="o">//</span> <span class="err">浅粉色</span><span class="n">UI</span>
</span></span><span class="line"><span class="cl"><span class="n">rate</span> <span class="mi">786432</span> <span class="o">//</span> <span class="err">游戏最大流量带宽</span>
