</span></span><span class="line"><span class="cl"><span class="o">//</span><span class="n">cl_hud_radar_background_alpha</span> <span class="mf">0.63</span>  <span class="o">//</span> <span class="err">雷达</span><span class="n">HUD背景透明度</span><span class="p">(</span><span class="mi">0</span><span class="o">~</span><span class="mi">1</span><span class="p">)</span>
</span></span><span class="line"><span class="cl"><span class="o">//</span><span class="n">cl_radar_scale_dynamic</span> <span class="mi">0</span>            <span class="o">//</span> <span class="err">雷达动态缩放</span><span class="p">(</span><span class="mi">0</span><span class="o">--</span><span class="err">否，</span><span class="mi">1</span><span class="o">--</span><span class="err">是</span><span class="p">)</span>
</span></span><span class="line"><span class="cl"><span class="o">//</span><span class="n">hud_showtargetid</span> <span class="mi">1</span>                  <span class="o">//</span> <span class="err">显示队友</span><span class="o">/</span><span class="err">敌人</span><span class="n">id</span>
