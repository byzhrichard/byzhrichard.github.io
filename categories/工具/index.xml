        <![CDATA[<h1>[工具] Obsidian</h1><p>作者：byzh（xxx@example.com）</p>
        
          <h1 id="插件">
<a class="header-anchor" href="#%e6%8f%92%e4%bb%b6"></a>
插件
</h1><h3 id="1-settings-search">
<a class="header-anchor" href="#1-settings-search"></a>
1. Settings Search
</h3><h3 id="2-recent-files">
<a class="header-anchor" href="#2-recent-files"></a>
2. Recent Files
</h3><h2 id="项目配置">
<a class="header-anchor" href="#%e9%a1%b9%e7%9b%ae%e9%85%8d%e7%bd%ae"></a>
项目配置
</h2><h3 id="1-obsidianappjson">
<a class="header-anchor" href="#1-obsidianappjson"></a>
1. <code>.obsidian/app.json</code>
</h3><div class="highlight"><pre tabindex="0" class="chroma"><code class="language-json" data-lang="json"><span class="line"><span class="cl"><span class="p">{</span>
</span></span><span class="line"><span class="cl">  <span class="nt">&#34;attachmentFolderPath&#34;</span><span class="p">:</span> <span class="s2">&#34;./&#34;</span>
