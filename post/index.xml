      <description>
        <![CDATA[<h1>[Windows] 变量名</h1><p>作者：byzh（xxx@example.com）</p>
        
          <h2 id="变量名">
<a class="header-anchor" href="#%e5%8f%98%e9%87%8f%e5%90%8d"></a>
变量名
</h2><table>
  <thead>
      <tr>
          <th style="text-align: left">变量</th>
          <th style="text-align: left">典型值</th>
          <th style="text-align: left">说明</th>
      </tr>
  </thead>
  <tbody>
      <tr>
          <td style="text-align: left"><code>%USERPROFILE%</code></td>
          <td style="text-align: left"><code>C:\Users\byzh</code></td>
          <td style="text-align: left"><strong>当前用户主目录</strong></td>
      </tr>
      <tr>
          <td style="text-align: left"><code>%APPDATA%</code></td>
          <td style="text-align: left"><code>C:\Users\byzh\AppData\Roaming</code></td>
          <td style="text-align: left">漫游应用数据</td>
      </tr>
      <tr>
          <td style="text-align: left"><code>%LOCALAPPDATA%</code></td>
          <td style="text-align: left"><code>C:\Users\byzh\AppData\Local</code></td>
          <td style="text-align: left">本地应用数据</td>
      </tr>
      <tr>
          <td style="text-align: left"><code>%TEMP%</code> / <code>%TMP%</code></td>
          <td style="text-align: left"><code>C:\Users\byzh\AppData\Local\Temp</code></td>
          <td style="text-align: left">临时文件夹</td>
      </tr>
      <tr>
          <td style="text-align: left"><code>%HOMEPATH%</code></td>
          <td style="text-align: left"><code>\Users\byzh</code></td>
          <td style="text-align: left">用户目录路径（不含盘符）</td>
      </tr>
      <tr>
          <td style="text-align: left"><code>%HOMEDRIVE%</code></td>
          <td style="text-align: left"><code>C:</code></td>
          <td style="text-align: left">系统盘符</td>
      </tr>
      <tr>
          <td style="text-align: left"><code>%USERNAME%</code></td>
          <td style="text-align: left"><code>byzh</code></td>
          <td style="text-align: left">当前用户名</td>
      </tr>
      <tr>
          <td style="text-align: left"><code>%COMPUTERNAME%</code></td>
          <td style="text-align: left"><code>PC-xxx</code></td>
          <td style="text-align: left">计算机名</td>
      </tr>
      <tr>
          <td style="text-align: left"><code>%PROGRAMFILES%</code></td>
          <td style="text-align: left"><code>C:\Program Files</code></td>
          <td style="text-align: left">64位程序安装目录</td>
      </tr>
      <tr>
          <td style="text-align: left"><code>%PROGRAMFILES(X86)%</code></td>
          <td style="text-align: left"><code>C:\Program Files (x86)</code></td>
          <td style="text-align: left">32位程序安装目录</td>
      </tr>
      <tr>
          <td style="text-align: left"><code>%SYSTEMROOT%</code></td>
          <td style="text-align: left"><code>C:\Windows</code></td>
          <td style="text-align: left">Windows 系统目录</td>
      </tr>
  </tbody>
</table>
        
